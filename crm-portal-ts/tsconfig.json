{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "emitDecoratorMetadata": false,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": [
    "src/app.ts",
    "src/main.ts",
    "src/database.ts",
    "src/router_aggregator.ts",
    "src/module_status.ts",
    "src/audit.ts",
    "src/backups.ts",
    "src/models/common.ts",
    "src/models/customer.ts",
    "src/models/finance.ts",
    "src/models/helpdesk.ts",
    "src/models/location.ts",
    "src/models/network.ts",
    "src/models/system.ts",
    "src/storage.ts",
    "src/teryt_import.ts",
    "src/routers/addresses.ts",
    "src/routers/admin.ts",
    "src/routers/architect.ts",
    "src/routers/customer_groups.ts",
    "src/routers/customer_devices.ts",
    "src/routers/customers.ts",
    "src/routers/dashboard.ts",
    "src/routers/diagnostics.ts",
    "src/routers/documents.ts",
    "src/routers/finances.ts",
    "src/routers/helpdesk.ts",
    "src/routers/ip_networks.ts",
    "src/routers/net_nodes.ts",
    "src/routers/netdevices.ts",
    "src/routers/network_discovery.ts",
    "src/routers/pit.ts",
    "src/routers/subscriptions.ts",
    "src/routers/teryt.ts",
    "src/tests/**/*.ts"
  ],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
