kind: source
name: crm-db
type: sqlite
database: "C:/Users/xxx/crm-portal/crm.sqlite"

---
kind: tool
name: crm_execute_sql
type: sqlite-sql
source: crm-db
description: Execute any SQL statement against the CRM database.
statement: "{{.sql}}"
templateParameters:
  - name: sql
    type: string
    description: The SQL statement to execute.

---
kind: tool
name: crm_list_tables
type: sqlite-sql
source: crm-db
description: List all tables in the CRM database.
statement: "SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%';"

---
kind: tool
name: crm_describe_table
type: sqlite-sql
source: crm-db
description: Describe the schema of a specific table.
statement: "PRAGMA table_info({{.table_name}});"
templateParameters:
  - name: table_name
    type: string
    description: Name of the table to describe.

---
kind: tool
name: crm_search_customers
type: sqlite-sql
source: crm-db
description: Search for customers by name or code.
statement: "SELECT id, customer_code, first_name, last_name, email FROM customers WHERE first_name LIKE ? OR last_name LIKE ? OR customer_code LIKE ?;"
parameters:
  - name: first_name
    type: string
    description: First name (with % wildcards)
  - name: last_name
    type: string
    description: Last name (with % wildcards)
  - name: customer_code
    type: string
    description: Customer code (with % wildcards)

---
kind: tool
name: crm_recent_tickets
type: sqlite-sql
source: crm-db
description: List the most recent support tickets.
statement: "SELECT id, title, status, created_at FROM support_tickets ORDER BY created_at DESC LIMIT 10;"
